        }
    }
}
@b pivot-table-popover-search {
    position: relative;
    height: 41px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    @e input {
        composes: absolute input from global;
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        padding-left: 40px;
        font-size: 0.75rem;
        font-weight: 500;
        color: rgba(0, 0, 0, 0.6);
        border-radius: 0;
        border: none;
        animation: none;
        outline: none;
        &::placeholder {
            text-transform: uppercase;
        }
    }
    @e icon {
        composes: absolute mdi mdi-magnify from global;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(0, 0, 0, 0.4);
        left: 0;
        top: 0;
        bottom: 0;
        width: 40px;
    }
}

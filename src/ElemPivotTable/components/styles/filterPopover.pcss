@b pivot-table-popover {
    composes: bg-white from global;
    width: 240px;
    filter: drop-shadow(0px 0px 4px rgba(0, 0, 0, 0.16));
}
@b pivot-table-popover-scroller {
    height: var(--w-height);
}
@b pivot-table-popover-collapse {
    composes: pad-3 from global;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    font-size: 0.875rem;
    line-height: 1.5rem;
    @e heading {
        composes: row row-collapse flex-nowrap cursor-pointer from global;
    }
    @e body {
        font-size: 0.75rem;
        line-height: 1rem;
    }
    @e title {
        composes: col col-v-mid from global;
    }
    @e icon {
        composes: col col-v-mid col-auto from global;
        @m rotate {
            transform: rotate(45deg);
        }
    }
    @e condition {
        composes: grid mar-top-3 from global;
        grid-template-columns: 4rem 1fr;
        grid-column-gap: 1rem;
    }
    @e operators {
        composes: d-flex mar-top-3 from global;
    }
    @e input {
        composes: input from global;
        min-width: 1px;
    }
}
@b pivot-table-popover-tools {
    composes: row row-collapse pad-3 justify-between from global;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    @e elem {
        composes: col col-auto col-vmid from global;
        & + & {
            margin-left: 0.5rem;
        }
    }
}
@b pivot-table-popover-button {
    composes: black cursor-pointer from global;
    font-size: 0.75rem;
    padding: 0 0.25rem;
    align-items: center;
    line-height: 1.5rem;
    border-radius: 0.25rem;
    background: #fff;
    box-shadow: 0 0 4px 0 rgba(0, 0, 0, 0.16);
    @m colored {
        color: #fff;
        background: #146ff8;
    }
}

@b pivot-table-popover-control {
    composes: row row-collapse from global;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    padding: 0 11px;
    font-size: 14px;
    line-height: 1.5;

    @e control-container {
        composes: col col-auto col-vmid mr-2 from global;
    }
    @e color {
        composes: inline-block text-center pad-h-2 mr-2 from global;
        font-size: 0.875rem;
        line-height: 1.5rem;
        border: 1px solid var(--border-color);
        border-radius: 4px;
    }
    @e label {
        composes: col col-vmid text-small text-truncate from global;
        @m center {
            composes: text-center from global;
        }
    }
}
@b pivot-table-popover-sort {
    composes: flex items-start flex-row pad-3 from global;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);

    @e label {
        flex: 1 1 auto;
        font-weight: 400;
        font-size: 0.875rem;
        line-height: 1.5rem;
        color: #000;
    }
    @e value {
        composes: mar-left-3 flex from global;
        width: 1.5rem;
        height: 1.5rem;
        align-items: center;
        justify-content: center;
        background-color: rgba(0, 132, 255, 0.16);
        background-repeat: no-repeat;
        background-position: center;
        background-size: 16px 11px;
        border-radius: 4px;
        cursor: pointer;
        @m active {
            background-color: #146ff8;
        }

{
    "name": "Insight Widgets Dev",
    "initializeCommand": "docker load -i insight-widgets.tar.gz || exit 0",
    "dockerComposeFile": ["../docker-compose.yml"],
    "service": "widgets-dev",
    "workspaceFolder": "/app",
    "forwardPorts": [3001],
    "portsAttributes": {
        "3001": {
            "label": "Widgets dev server",
            "onAutoForward": "notify"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "Vue.volar",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode"
            ]
        }
    },
    "shutdownAction": "stopCompose"
}
